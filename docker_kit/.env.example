# Copiez ce fichier en `.env` (jamais commité) et générez des secrets forts :
#   cp .env.example .env
#   sed -i "s#CHANGE_ME_DB_PASSWORD#$(openssl rand -base64 24 | tr -d '\n')#" .env
#   sed -i "s#CHANGE_ME_DB_ROOT_PASSWORD#$(openssl rand -base64 24 | tr -d '\n')#" .env
#   chmod 600 .env

DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_DB_ROOT_PASSWORD
