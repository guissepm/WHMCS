# =============================================================================
# Vhost NGINX HÔTE pour boutique.syskabsamazone.com
# À installer sur le VPS (PAS dans le conteneur) : /etc/nginx/sites-available/
# puis `ln -s` dans sites-enabled et `nginx -t && systemctl reload nginx`.
#
# Hypothèse : le VPS a déjà Nginx installé nativement en reverse-proxy devant
# une autre application. Si c'est Traefik (ou autre) à la place, voir la
# section 2 "Cas Traefik" de README_DOCKER.md — ignorez ce fichier.
#
# Étapes avant d'activer ce vhost :
#   1. DNS : créez un enregistrement A `boutique` -> IP du VPS dans l'espace
#      client LWS (zone DNS de syskabsamazone.com).
#   2. Certificat : obtenez-le AVANT d'activer le bloc 443 ci-dessous :
#        certbot certonly --nginx -d boutique.syskabsamazone.com
#      (ou --webroot si votre Nginx sert déjà du contenu statique ici)
# =============================================================================

# --- Redirection HTTP -> HTTPS ---
server {
    listen 80;
    listen [::]:80;
    server_name boutique.syskabsamazone.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# --- HTTPS : proxy vers le conteneur nginx WHMCS (127.0.0.1:8081) ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name boutique.syskabsamazone.com;

    ssl_certificate     /etc/letsencrypt/live/boutique.syskabsamazone.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/boutique.syskabsamazone.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    client_max_body_size 32M;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    # Limite les tentatives de brute-force sur l'admin WHMCS (voir zone
    # `limit_req_zone` à déclarer une seule fois dans http{} de nginx.conf :
    #   limit_req_zone $binary_remote_addr zone=whmcs_admin:10m rate=10r/m;
    location /admin/ {
        limit_req zone=whmcs_admin burst=5 nodelay;
        proxy_pass http://127.0.0.1:8081;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }

    location / {
        proxy_pass http://127.0.0.1:8081;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}
